{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "ai-translate",
  "title": "AI Translate",
  "description": "Translate text between languages using Claude AI",
  "icon": "extension-icon.png",
  "author": "thalys",
  "categories": ["Productivity"],
  "license": "MIT",
  "preferences": [
    {
      "name": "apiKey",
      "title": "Anthropic API Key",
      "description": "Your Anthropic API key for Claude",
      "type": "password",
      "required": true
    },
    {
      "name": "defaultTargetLanguage",
      "title": "Default Target Language",
      "description": "Default language to translate into",
      "type": "dropdown",
      "required": false,
      "default": "en",
      "data": [
        { "title": "English", "value": "en" },
        { "title": "Portuguese (BR)", "value": "pt-br" },
        { "title": "Spanish", "value": "es" },
        { "title": "French", "value": "fr" },
        { "title": "German", "value": "de" },
        { "title": "Italian", "value": "it" },
        { "title": "Japanese", "value": "ja" },
        { "title": "Korean", "value": "ko" },
        { "title": "Chinese", "value": "zh" },
        { "title": "Russian", "value": "ru" }
      ]
    }
  ],
  "commands": [
    {
      "name": "translate",
      "title": "Translate Text",
      "subtitle": "AI Translate",
      "description": "Translate text between languages using Claude AI",
      "mode": "view"
    },
    {
      "name": "translate-clipboard",
      "title": "Translate Clipboard",
      "subtitle": "AI Translate",
      "description": "Translate clipboard content between languages using Claude AI",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@raycast/api": "^1.93.0",
    "@raycast/utils": "^1.18.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  }
}
